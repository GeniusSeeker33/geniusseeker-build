# Server
PORT=8787
CORS_ORIGIN=*

# Hedera (Testnet recommended first)
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.xxxxx
HEDERA_OPERATOR_KEY=302e...

# Optional: use a pre-created NFT token for badges/credentials (recommended)
HEDERA_BADGE_TOKEN_ID=0.0.xxxxx
HEDERA_CREDENTIAL_TOKEN_ID=0.0.xxxxx

# Filebase/IPFS (optional for v1; can start with inline metadata)
FILEBASE_GATEWAY_BASE=https://damaged-rose-sloth.myfilebase.com/ipfs/
